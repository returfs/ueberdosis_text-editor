# Returfs Developer API Key
# Get this from: Settings > Developer > API Keys
VITE_RETURFS_API_KEY=rfsk_your_api_key_here

# API URL (optional - defaults to proxy)
# VITE_RETURFS_API_URL=http://project.test

# Hocuspocus WebSocket URL (for real-time collaboration)
VITE_HOCUSPOCUS_URL=ws://localhost:1234
